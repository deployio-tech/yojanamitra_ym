# YojanaMitra Environment Variables
# Copy this to .env and fill in your values

# ========== REQUIRED ==========
# Get from: https://ai.google.dev/
GEMINI_API_KEY=your-gemini-api-key-here

# Change this to a random secure string in production
SECRET_KEY=your-secret-key-change-in-production

# ========== DATABASE CONFIGURATION ==========
# Option 1: PostgreSQL (recommended for production)
DATABASE_URL=postgresql+psycopg2://yojana:yojana_pass_123@db:5432/yojanamitra_db

# Option 2: SQLite (simple, single server)
# DATABASE_URL=sqlite:///yojanamitra.db

# ========== DATABASE CREDENTIALS (for docker-compose) ==========
DB_USER=yojana
DB_PASSWORD=yojana_pass_123
DB_NAME=yojanamitra_db

# ========== OPTIONAL ==========
# Email configuration (if using email notifications)
EMAIL_ADDRESS=your-email@gmail.com
EMAIL_PASSWORD=your-app-password

# SMS configuration (if using SMS notifications)
TWILIO_ACCOUNT_SID=your-twilio-sid
TWILIO_AUTH_TOKEN=your-twilio-token
TWILIO_PHONE_NUMBER=+1234567890

# Google OAuth (if using)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Application settings
FLASK_ENV=production
FLASK_APP=app.py
DEBUG=false
